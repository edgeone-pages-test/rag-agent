# LLM Gateway Configuration
# Required: OpenAI-compatible LLM API credentials
AI_GATEWAY_API_KEY=your-api-key
AI_GATEWAY_BASE_URL=https://your-openai-compatible-endpoint/v1

# Optional: model name (defaults to @makers/hy3-preview)
AI_GATEWAY_MODEL=@makers/hy3-preview

# Optional: disable OpenAI Agents tracing in local/demo environments
OPENAI_AGENTS_DISABLE_TRACING=1
